/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-core/oceangenomesmitogenomes Nextflow base config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    A 'blank slate' config file, appropriate for general use on most high performance
    compute environments. Assumes that all software is installed and available on
    the PATH. Runs in `local` mode - all jobs will be run on the logged in environment.
----------------------------------------------------------------------------------------
*/

//
// Memory hints for attempt-scaled processes (OATK, GETORGANELLE_RESEED,
// GETORGANELLE_FROMREADS). PIPELINE_COMPLETION's onComplete handler (see
// subworkflows/local/utils_nfcore_oceangenomesmitogenomes_pipeline) records,
// per sample, the memory tier a retried task actually succeeded at. Without
// this, -resume restarts that sample's attempt counter at 1: the resolved
// memory (and therefore the task hash) never matches the cached success, so
// the default low tier reruns -- and re-fails -- before climbing back to the
// tier that worked. Loaded once at config-parse time; a missing/empty file
// is a no-op and falls back to the standard `100.GB * task.attempt` ladder.
//
def _memory_hints_file = params.outdir ? new File("${params.outdir}/pipeline_info/memory_hints.json") : null
// `def` (a script-local var, not a bare binding) is deliberate: an unqualified
// top-level assignment here gets picked up by Nextflow's config-attribute
// validation, and an *empty* map assigned that way (the common case -- no
// hints recorded yet) is rejected at parse time with "Unknown config
// attribute `memoryHints`" (verified; a populated map did not trigger it,
// which made this easy to miss testing only the happy path). Kept `def`-local
// and passed explicitly into hintedMemory() below instead, since a directive
// closure (unlike a plain method) does correctly capture an enclosing `def`.
def memoryHints = [:]
if (_memory_hints_file && _memory_hints_file.exists()) {
    try {
        memoryHints = new groovy.json.JsonSlurper().parse(_memory_hints_file) as Map
    } catch (Exception e) {
        // `log` isn't bound at config-parse time (ConfigSlurper auto-vivifies
        // it as an empty ConfigObject, so `log.warn(...)` fails with
        // "Unknown method invocation `warn`" -- verified). Use stderr instead.
        System.err.println("WARN: could not parse memory hints file ${_memory_hints_file}: ${e.message} -- ignoring")
    }
}

// Hinted memory (GB) for `sampleId` on `processName`'s first attempt if one
// was recorded from a previous run; otherwise the standard escalating tier.
// `hints` is passed explicitly (rather than read from an enclosing variable)
// because hintedMemory() is a plain method: methods don't participate in
// Groovy closure-capture the way the `memory = { hintedMemory(memoryHints, ...) }`
// call site does, so a method body can't see a sibling top-level `def` directly.
def hintedMemory(hints, processName, taskAttempt, sampleId) {
    def hint = hints[processName]?.get(sampleId)
    if (taskAttempt == 1 && hint) {
        return (hint as Integer).GB
    }
    return Math.min(230, 100 * taskAttempt).GB
}

process {

    // TODO nf-core: Check the defaults for all processes
    cpus   = { 1      * task.attempt }
    memory = { 6.GB   * task.attempt }
    time   = { 4.h    * task.attempt }

    maxRetries    = 2
    errorStrategy = {
        def retries = task.maxRetries ?: 0
        def transient_failure = task.exitStatus == null || task.exitStatus in ((130..145) + 104 + 247)
        transient_failure && task.attempt <= retries ? 'retry' : 'ignore'
    }
    // A failed sample must not abort a cohort run. Transient failures are retried;
    // deterministic or exhausted failures are reported and left for a later -resume.
    maxErrors     = '-1'

    // Process-specific resource requirements
    // NOTE - Please try and reuse the labels below as much as possible.
    //        These labels are used and recognised by default in DSL2 files hosted on nf-core/modules.
    //        If possible, it would be nice to keep the same label naming convention when
    //        adding in your local modules too.
    // TODO nf-core: Customise requirements for specific processes.
    // See https://www.nextflow.io/docs/latest/config.html#config-process-selectors
    withLabel:process_single {
        cpus   = { 1                   }
        memory = { 6.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withLabel:process_low {
        cpus   = { 2     * task.attempt }
        memory = { 12.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel:process_medium {
        cpus   = { 6     * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { Math.min( 24, 8 * task.attempt ).h }
    }
    withLabel:process_high {
        cpus   = 12
        memory = { 72.GB * task.attempt }
        time   = { Math.min( 24, 16 * task.attempt ).h }
    }
    withLabel:process_long {
        time   = { 20.h  * task.attempt }
    }
    withLabel:process_high_memory {
        memory = { 200.GB * task.attempt }
    }
    // withLabel:error_ignore {
    //     errorStrategy = 'ignore'
    // }
    // withLabel:error_retry {
    //     errorStrategy = 'retry'
    //     maxRetries    = 2
    // }
    withLabel: process_gpu {
        ext.use_gpu = { workflow.profile.contains('gpu') }
        accelerator = { workflow.profile.contains('gpu') ? 1 : null }
    }
    withName: MITOHIFI_FINDMITOREFERENCE {
        // Retry transient NCBI failures, then leave the affected sample for -resume.
        errorStrategy = { task.attempt <= 3 ? 'retry' : 'ignore' }
        maxRetries = 3
    }
    withName:GETORGANELLE_FROMREADS {
        cpus   = 16
        memory = { hintedMemory(memoryHints, 'GETORGANELLE_FROMREADS', task.attempt, task.tag) }
        time   = { Math.min( 24, 16 * task.attempt ).h }
    }
    withName:GETORGANELLE_RESEED {
        cpus   = 16
        memory = { hintedMemory(memoryHints, 'GETORGANELLE_RESEED', task.attempt, task.tag) }
        time   = { Math.min( 24, 16 * task.attempt ).h }
        maxRetries = 2
        errorStrategy = {
            def transient_failure = task.exitStatus == null || task.exitStatus == 137
            transient_failure && task.attempt <= task.maxRetries ? 'retry' : 'ignore'
        }
    }
    withName:OATK {
        // Reference-free HiFi fallback; overrides the module's process_medium label.
        // OG109 exhausted the former 24 GB allocation (23.6 GB peak RSS). Retry
        // an OOM/resource kill or a missing Slurm exit status, escalating memory
        // only on subsequent attempts.
        cpus   = 8
        memory = { hintedMemory(memoryHints, 'OATK', task.attempt, task.tag) }
        time   = { Math.min( 24, 8 * task.attempt ).h }
        maxRetries = 2
        errorStrategy = {
            def transient_failure = task.exitStatus == null || task.exitStatus == 137
            transient_failure && task.attempt <= task.maxRetries ? 'retry' : 'ignore'
        }
    }
    withName: /DOWNLOAD_BLAST_DB|DOWNLOAD_TAXONKIT_DB|PREPARE_LCA_DATABASES/ {
        // These singleton tasks provide shared prerequisites for the entire cohort.
        // Retry infrastructure/resource failures, but terminate rather than allowing
        // hundreds of samples to continue without a valid database.
        maxRetries = 2
        errorStrategy = {
            def transient_failure = task.exitStatus == null || task.exitStatus in ((130..145) + 104 + 247)
            transient_failure && task.attempt <= task.maxRetries ? 'retry' : 'terminate'
        }
    }
    withName:PREPARE_LCA_DATABASES {
        // Always revalidate the external persistent cache; valid files make this
        // cheap, while a deleted/corrupt cache must never be hidden by -resume.
        cache = false
    }
}
