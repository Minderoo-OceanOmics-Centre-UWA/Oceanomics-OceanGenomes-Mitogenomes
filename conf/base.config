/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    nf-core/oceangenomesmitogenomes Nextflow base config file
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    A 'blank slate' config file, appropriate for general use on most high performance
    compute environments. Assumes that all software is installed and available on
    the PATH. Runs in `local` mode - all jobs will be run on the logged in environment.
----------------------------------------------------------------------------------------
*/

process {

    // TODO nf-core: Check the defaults for all processes
    cpus   = { 1      * task.attempt }
    memory = { 6.GB   * task.attempt }
    time   = { 4.h    * task.attempt }

    maxRetries    = 2
    errorStrategy = {
        def retries = task.maxRetries ?: 0
        def transient_failure = task.exitStatus == null || task.exitStatus in ((130..145) + 104 + 247)
        transient_failure && task.attempt <= retries ? 'retry' : 'ignore'
    }
    // A failed sample must not abort a cohort run. Transient failures are retried;
    // deterministic or exhausted failures are reported and left for a later -resume.
    maxErrors     = '-1'

    // Process-specific resource requirements
    // NOTE - Please try and reuse the labels below as much as possible.
    //        These labels are used and recognised by default in DSL2 files hosted on nf-core/modules.
    //        If possible, it would be nice to keep the same label naming convention when
    //        adding in your local modules too.
    // TODO nf-core: Customise requirements for specific processes.
    // See https://www.nextflow.io/docs/latest/config.html#config-process-selectors
    withLabel:process_single {
        cpus   = { 1                   }
        memory = { 6.GB * task.attempt }
        time   = { 4.h  * task.attempt }
    }
    withLabel:process_low {
        cpus   = { 2     * task.attempt }
        memory = { 12.GB * task.attempt }
        time   = { 4.h   * task.attempt }
    }
    withLabel:process_medium {
        cpus   = { 6     * task.attempt }
        memory = { 36.GB * task.attempt }
        time   = { Math.min( 24, 8 * task.attempt ).h }
    }
    withLabel:process_high {
        cpus   = 12
        memory = { 72.GB * task.attempt }
        time   = { Math.min( 24, 16 * task.attempt ).h }
    }
    withLabel:process_long {
        time   = { 20.h  * task.attempt }
    }
    withLabel:process_high_memory {
        memory = { 200.GB * task.attempt }
    }
    // withLabel:error_ignore {
    //     errorStrategy = 'ignore'
    // }
    // withLabel:error_retry {
    //     errorStrategy = 'retry'
    //     maxRetries    = 2
    // }
    withLabel: process_gpu {
        ext.use_gpu = { workflow.profile.contains('gpu') }
        accelerator = { workflow.profile.contains('gpu') ? 1 : null }
    }
    withName: MITOHIFI_FINDMITOREFERENCE {
        // Retry transient NCBI failures, then leave the affected sample for -resume.
        errorStrategy = { task.attempt <= 3 ? 'retry' : 'ignore' }
        maxRetries = 3
    }
    withName:GETORGANELLE_FROMREADS {
        cpus   = 16
        memory = { Math.min( 230, 100 * task.attempt ).GB }
        time   = { Math.min( 24, 16 * task.attempt ).h }
    }
    withName:GETORGANELLE_RESEED {
        cpus   = 16
        memory = { Math.min( 230, 100 * task.attempt ).GB }
        time   = { Math.min( 24, 16 * task.attempt ).h }
        maxRetries = 2
        errorStrategy = {
            def transient_failure = task.exitStatus == null || task.exitStatus == 137
            transient_failure && task.attempt <= task.maxRetries ? 'retry' : 'ignore'
        }
    }
    withName:OATK {
        // Reference-free HiFi fallback; overrides the module's process_medium label.
        // OG109 exhausted the former 24 GB allocation (23.6 GB peak RSS). Retry
        // an OOM/resource kill or a missing Slurm exit status, escalating memory
        // only on subsequent attempts.
        cpus   = 8
        memory = { Math.min( 230, 100 * task.attempt ).GB }
        time   = { Math.min( 24, 8 * task.attempt ).h }
        maxRetries = 2
        errorStrategy = {
            def transient_failure = task.exitStatus == null || task.exitStatus == 137
            transient_failure && task.attempt <= task.maxRetries ? 'retry' : 'ignore'
        }
    }
    withName: /DOWNLOAD_BLAST_DB|DOWNLOAD_TAXONKIT_DB|PREPARE_LCA_DATABASES/ {
        // These singleton tasks provide shared prerequisites for the entire cohort.
        // Retry infrastructure/resource failures, but terminate rather than allowing
        // hundreds of samples to continue without a valid database.
        maxRetries = 2
        errorStrategy = {
            def transient_failure = task.exitStatus == null || task.exitStatus in ((130..145) + 104 + 247)
            transient_failure && task.attempt <= task.maxRetries ? 'retry' : 'terminate'
        }
    }
    withName:PREPARE_LCA_DATABASES {
        // Always revalidate the external persistent cache; valid files make this
        // cheap, while a deleted/corrupt cache must never be hidden by -resume.
        cache = false
    }
}
