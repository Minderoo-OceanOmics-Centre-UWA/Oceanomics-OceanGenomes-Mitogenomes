/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Reference-free HiFi mitogenome fallback (Oatk)
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    MitoHiFi recruits reads by mapping to a related-species reference; for taxa with
    no close NCBI relative (a divergent / cross-order reference) that maps ~zero
    reads and produces no contig. Oatk instead identifies the mitogenome by
    profile-HMM over a de-novo HiFi assembly, so it needs no species reference and
    recovers exactly those divergent-reference failures.

    Enable with:
        nextflow run main.nf <your opts> \
            -c conf/oatk.config \
            --enable_oatk_fallback true \
            --oatk_mito_db /path/to/actinopterygii_mito.fam

    Fetch the OatkDB profile for your clade first (ray-finned fish shown):
        bash bin/download_oatk_db.sh actinopterygii_mito /path/to/oatk_db
    then point --oatk_mito_db at <dir>/actinopterygii_mito.fam (its .h3f/.h3i/.h3m/.h3p
    index files must sit next to it).

    Runs only on samples MitoHiFi failed to assemble; off by default.
*/

params {
    enable_oatk_fallback  = false
    // biocontainer bundles oatk + syncasm + nhmmscan (hmmer >=3.4).
    oatk_container        = 'quay.io/biocontainers/oatk:1.0--h577a1d6_1'
    // REQUIRED when enabled: OatkDB mitochondrial profile-HMM (.fam) for the clade.
    oatk_mito_db          = null
    oatk_syncmer_size     = 1001
    oatk_syncmer_coverage = 30
}

process {
    withName: 'OATK' {
        cpus   = { 8 * task.attempt }
        memory = { 24.GB * task.attempt }
        time   = { 4.h * task.attempt }
    }
}
