/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Config file for defining DSL2 per module options and publishing paths
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Available keys to override module options:
        ext.args   = Additional arguments appended to command in module.
        ext.args2  = Second set of arguments appended to command in module (multi-tool modules).
        ext.args3  = Third set of arguments appended to command in module (multi-tool modules).
        ext.prefix = File name prefix for output files.
----------------------------------------------------------------------------------------
*/

process {

    publishDir = [
        path: { "${params.outdir}/${task.process.tokenize(':')[-1].tokenize('_')[0].toLowerCase()}" },
        mode: params.publish_dir_mode,
        saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
    ]

    withName: CREATE_SAMPLESHEET {
        publishDir = [
            path: { "${params.outdir}/samplesheet" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: FASTP {
        // Adapter trimming is automatic (overlap analysis); --trim_poly_g removes
        // the NovaSeq 2-colour poly-G tails that otherwise assemble onto contig
        // ends and stop GetOrganelle circularising. --dedup drops HiC PCR
        // duplicates. Override via params.hic_fastp_args.
        ext.args = params.hic_fastp_args ?: '--trim_poly_g --cut_tail --dedup --length_required 100'
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/fastp" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                (filename.endsWith('.fastq.gz') || filename.endsWith('.tool_params_mqcrow.html') || filename.equals('versions.yml')) ? null : filename
            }
        ]
    }

    withName: GETORGANELLE_FROMREADS {
        ext.args = params.getorganelle_fromreads_args ?: '-R 20 -w 95 --continue'
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.tool_params_mqcrow.html') ? null : filename }
        ]
    }

    withName: GETORGANELLE_RESEED {
        ext.args = params.getorganelle_fromreads_args ?: '-R 20 -w 95 --continue'
        // Reseed outputs are named "<prefix>reseed" and the annotation/LCA/QC
        // stages re-derive their publish dir from that fasta basename, so publish
        // the reseed assembly into the matching "<prefix>reseed" dir rather than
        // the first-pass "<prefix>" dir (keeps the reseed assembly with its
        // downstream annotation/lca/qc results).
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}reseed" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.tool_params_mqcrow.html') ? null : filename }
        ]
    }

    withName: GETORGANELLE_GENEDB {
        ext.args = 'CDS,rRNA'
        // Gene database is extracted from the reseed reference GenBank, so publish
        // it alongside that reference (seed FASTA + GenBank) in the reseed's
        // "mtdna/reference_seed" dir rather than loose at the reseed dir root.
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}reseed/mtdna/reference_seed" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.tool_params_mqcrow.html') ? null : filename }
        ]
    }

    withName: GETORGANELLE_JOIN {
        // Joined assembly + evidence are named "<assembly_prefix>_rgj"; publish them
        // into the matching "<assembly_prefix>_rgj" assembly dir (derived from the
        // filename, the same convention the reseed/check stages use) so the joined
        // molecule sits with the downstream annotation/LCA/QC that re-derive their
        // dirs from this fasta. The pre-join scaffolds remain in the source assembly
        // dir. The passed-through reference GenBank is not republished here.
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html') || filename.endsWith('.gb')) return null
                def base = filename - ~/\.(fa|fasta|fna)$/ - ~/\.scaffold_join\.tsv$/
                return "${base}/mtdna/${filename}"
            }
        ]
    }

    withName: GETORGANELLE_CHECK {
        // The evidence is named <assembly_prefix>.getorg_check.tsv, carrying the
        // "reseed" suffix when the reseed assembly was evaluated. Derive the
        // assembly subdir from that filename so the verdict is published beside the
        // assembly it actually tested (reseed dir vs first-pass dir) rather than
        // always landing in the first-pass dir.
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) return null
                def base = filename - ~/\.getorg_check\.tsv$/
                return "${base}/mtdna/${filename}"
            }
        ]
    }

    withName: MITOHIFI_MITOHIFI {
        ext.args = ''
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/mtdna" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.endsWith('.tool_params_mqcrow.html')) return null
                def name = filename.tokenize('/').last()
                return name in ['reads_mapping_and_assembly', 'coverage_mapping'] ? null : filename
            }
        ]
    }

    withName: MITOHIFI_AVERAGE_COVERAGE {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/mtdna" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: MITOHIFI_CHECK_CIRCULARITY {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/mtdna" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) return null
                // The corrected stats lands in checked/; publish it flat alongside the other mtdna stats.
                return filename.startsWith('checked/') ? filename.tokenize('/').last() : filename
            }
        ]
    }

    withName: EMMA {
        ext.args = '--rotate MT-TF'
        errorStrategy = 'ignore'
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.tool_params_mqcrow.html') ? null : filename }
        ]
    }

    withName: ROTATE_ORIGIN {
        // Intermediate: the rotated assembly is republished by MITOS2 as
        // annotation/<prefix>.fa, so don't publish it separately here.
        errorStrategy = 'ignore'
        publishDir = [ enabled: false ]
    }

    withName: MITOS2 {
        // MITOS genetic code is now resolved per-sample from taxonomic class
        // (meta.genetic_code, set in PREPARE_SAMPLESHEET: Cnidaria -> 4, etc.) and
        // applied to both runmitos.py -c and the EMMA-contract protein translation.
        // Leave ext.code unset so meta.genetic_code is used; set it here only to
        // force a single code across ALL samples (overrides the per-sample value).
        // ext.code = 5
        errorStrategy = 'ignore'
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.tool_params_mqcrow.html') ? null : filename }
        ]
    }

    withName: ANNOTATION_QC_GATE {
        // Internal FIX/PASS decision for the anthozoan annotation fixer; not published.
        errorStrategy = 'ignore'
        publishDir = [ enabled: false ]
        // Tune the truncated-nad5 threshold here if needed, e.g.:
        // ext.args = '--min-nd5-aa 540'
    }

    withName: SELECT_CORAL_REFERENCE {
        // Label-free annotation-reference pick (BLAST assembly vs the curated coral
        // mito DB). Publishes the chosen reference + selection status into the
        // sample's annotation/ dir; merge-copy of only the declared outputs.
        errorStrategy = 'ignore'
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/annotation" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.versions.yml') || filename == 'versions.yml' ? null : filename }
        ]
        // Tune selection confidence thresholds here if needed, e.g.:
        // ext.args = '--min-cov 0.60 --min-pid 88.0'
    }

    withName: RELABEL_REFERENCE_GB {
        // Intermediate: renames the findMitoReference GenBank to a per-sample name so
        // it can be staged (collision-free) into REFERENCE_DIVERGENCE, REFERENCE_RELEVANCE
        // and the assembly summary. Those downstream steps consume it via work/, not via
        // publishDir, and every fact it carries (chosen reference species/accession, plus
        // congeneric/relevance verdicts) is already captured in the assembly summary and
        // the reference_divergence/reference_relevance flags. It is just a copy of a public
        // NCBI record, so don't publish it -- otherwise the default publishDir rule dumps
        // all of them flat into outdir/relabel/.
        publishDir = [ enabled: false ]
    }

    withName: REFERENCE_RELEVANCE {
        // Per-sample PASS/MISMATCH flag for whether the resolved reference actually
        // matches the assembly (a wrong species label -> wrong-family reference).
        // Published into the sample's existing annotation/ dir; also feeds the
        // assembly summary's manual_review_reason. publishDir copies (merges) only
        // the declared output file in -- it does not clear the directory -- and the
        // saveAs below restricts it to just the flag file (drops versions.yml).
        errorStrategy = 'ignore'
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/annotation" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.reference_relevance.txt') ? filename : null }
        ]
        // Tune relevance thresholds here if needed, e.g.:
        // ext.args = '--min-cov 0.60 --min-pid 88.0'
    }

    withName: REFERENCE_DIVERGENCE {
        // Pre-assembly taxonomy guard: per-sample CONGENERIC..NON_CONGENERIC flag for
        // how closely the resolved reference is related to the sample. A non-congeneric
        // reference is the leading cause of gene-incomplete MitoHiFi collapses for taxa
        // with no close NCBI relative; the flag feeds the assembly summary's
        // manual_review_reason. Published next to the reference/assembly in mtdna;
        // saveAs restricts it to just the flag file (drops versions.yml).
        errorStrategy = 'ignore'
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/mtdna" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.reference_divergence.txt') ? filename : null }
        ]
    }

    withName: CORAL_ANNOTATION_FIX {
        // Republishes the repaired annotation (with 16S + the nad5 join) over the
        // deficient MITOS2 output for FIX corals, into the same per-sample dir. The
        // fix artefacts (patched BED, status, reference) go in their own mitos_fix/
        // subdir so MITOS2's raw output in mitos_raw/ is preserved, not clobbered.
        errorStrategy = 'ignore'
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.tool_params_mqcrow.html') ? null : filename }
        ]
    }

    withName: '.*:MITOGENOME_ANNOTATION:MITOHIFI_FINDMITOREFERENCE' {
        // Reference fallback for the coral fixer: allow a failed NCBI lookup to be
        // ignored so the sample drops through to the bundled curated reference
        // instead of halting the run. (Scoped to the annotation subworkflow so the
        // assembly-stage use of this module is unaffected.)
        errorStrategy = 'ignore'
    }

    withName: BLAST_BLASTN {
        // Args differ by BLAST database (see mitogenome_annotation_lca subworkflow):
        //   vertebrates -> small curated DB (fast): keep the original sensitive settings.
        //   invertebrates -> full 256 GB core_nt (slow): use megablast + identity cutoff.
        // megablast (default task, 28-mer seeds) skips most of the DB and is 10-50x faster
        // than -task blastn against core_nt. The downstream filter keeps only span>200 &
        // pident>98, so -perc_identity 98 just cuts the discarded hitlist at source.
        ext.args = { [
                '-outfmt "6 qseqid sseqid staxids sscinames scomnames sskingdoms pident length qlen slen mismatch gapopen gaps qstart qend sstart send stitle evalue bitscore qcovs qcovhsp"',
                ( meta.invertebrates
                    ? '-max_target_seqs 500 -perc_identity 98 -evalue 1e-10'
                    : '-num_alignments 999999 -evalue 1 -task blastn' ),
            ].join(' ') }
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/lca" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.tool_params_mqcrow.html') ? null : filename }
        ]
    }

    withName: LCA {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/lca" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.endsWith('.tool_params_mqcrow.html') ? null : filename }
        ]
    }

    withName: 'MULTIQC' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: 'MULTIQC_PER_SAMPLE' {
        ext.args   = { params.multiqc_title ? "--title \"$params.multiqc_title\"" : '' }
        publishDir = [
            path: { "${params.outdir}/mitogenomes" },
            mode: params.publish_dir_mode,
            saveAs: { filename ->
                if (filename.equals('versions.yml')) return null
                return filename.startsWith('sample_multiqc_html/') ? filename.minus('sample_multiqc_html/') : filename
            }
        ]
    }

    withName: MITOGENOME_ASSEMBLY_SUMMARY {
        publishDir = [
            path: { "${params.outdir}/multiqc" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: FORMAT_FILES {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/genbank" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: BUILD_SOURCE_MODIFIERS {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/genbank" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> 
                if (filename.equals('versions.yml')) return null
                if (filename.endsWith('.tool_params_mqcrow.html')) return null
                return filename.startsWith('processed/') ? filename.minus('processed/') : filename
            }
        ]
    }

    withName: EXTRACT_GENES_GFF {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/genbank" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: TRANSLATE_GENES {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/genbank" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: GEN_FILES_TABLE2ASN {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/genbank" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    // Intermediate QC tables consumed by MultiQC and the ENA quarantine gate via
    // channels; the status content is republished under genbank/ena. No need to
    // also publish the raw per-sample TSVs to the default outdir/parse/ folder.
    withName: PARSE_TABLE2ASN_VALIDATION {
        publishDir = [ enabled: false ]
    }

    withName: ENA_FLATFILE {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/genbank/ena" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: WEBIN_VALIDATE {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/genbank/ena" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: ENA_EMBL_PREFLIGHT {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/genbank/ena" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: ENA_VALIDATION_RESULT {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/genbank/ena" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: ENA_VALIDATION_SUMMARY {
        publishDir = [
            path: { "${params.outdir}/ena" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> filename.equals('versions.yml') ? null : filename }
        ]
    }

    withName: PUSH_ENA_VALIDATION_RESULTS {
        publishDir = [
            path: { "${params.outdir}/sql_uploaded_data" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: PUSH_MTDNA_ASSM_RESULTS {
        ext.args = params.force_db_overwrite ? '--force' : ''
        publishDir = [
            path: { "${params.outdir}/sql_uploaded_data" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: PUSH_MTDNA_ANNOTATION_RESULTS {
        ext.args2 = params.force_db_overwrite ? '--force' : ''
        publishDir = [
            path: { "${params.outdir}/sql_uploaded_data" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: PUSH_LCA_BLAST_RESULTS {
        publishDir = [
            path: { "${params.outdir}/sql_uploaded_data" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: PUSH_LCA_RAW_RESULTS {
        ext.args = params.force_db_overwrite ? '--force' : ''
        publishDir = [
            path: { "${params.outdir}/sql_uploaded_data" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: UPLOAD_RESULTS_SUMMARY {
        publishDir = [
            path: { "${params.outdir}/sql_uploaded_data" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: SPECIES_VALIDATION {
        ext.args = params.force_db_overwrite ? '--force' : ''
        publishDir = [
            path: { "${params.outdir}/species_validation" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: HIC_DATE_QUERY {
        publishDir = [enabled: false]
    }

    withName: SPECIES_QUERY {
        publishDir = [enabled: false]
    }    

    withName: DOWNLOAD_BLAST_DB {
        publishDir = [enabled: false]
    }

    withName: DOWNLOAD_TAXONKIT_DB {
        publishDir = [enabled: false]
    }
    
    withName: GETORGANELLE_CONFIG {
        publishDir = [enabled: false]
    }

    withName: EVALUATE_QC_CONDITIONS {
        publishDir = [enabled: false]
    }

    withName: MITOHIFI_FINDMITOREFERENCE {
        publishDir = [enabled: false]
    }

    // In the MitoHiFi path the reference is published as part of MITOHIFI_MITOHIFI's
    // `MitoReference` output, so FINDMITOREFERENCE stays disabled (above). The
    // GetOrganelle path has no equivalent, so publish the reference (seed FASTA +
    // GenBank) used for the reseed alongside the reseed assembly. This qualified
    // selector appears after the generic one, so it wins for the GETORG invocation
    // only; the MITOHIFI invocation keeps publishDir disabled.
    withName: '.*:MITOGENOME_ASSEMBLY_GETORG:MITOHIFI_FINDMITOREFERENCE' {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}reseed/mtdna/reference_seed" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }

    withName: SANITISE_FASTA {
        publishDir = [enabled: false]
    }

    // Reference-free HiFi fallback. Only invoked when enable_oatk_fallback is set
    // (guarded in the subworkflow), so this block is inert on runs that don't use it.
    // Publishes the assembled contig/graph beside the sample's other assemblies, into
    // the per-sample mtdna dir, matching the MitoHiFi output convention it stands in for.
    withName: 'OATK' {
        publishDir = [
            path: { "${params.outdir}/mitogenomes/${meta.id}/${meta.mt_assembly_prefix}/mtdna" },
            mode: params.publish_dir_mode,
            saveAs: { filename -> (filename.equals('versions.yml') || filename.endsWith('.tool_params_mqcrow.html')) ? null : filename }
        ]
    }
}
